#!/bin/bash
# buc — Browser Use CLI
# Agent-agnostic browser automation via Chrome DevTools Protocol.
# Toggle requires sudo. Browser commands require enabled but not sudo.
#
# Usage:
#   buc status                      Show state (enabled/disabled, mode)
#   buc on [headed|headless|both]   Enable browser (requires sudo)
#   buc off                         Disable browser (requires sudo)
#   buc start [--headless]          Launch Chrome
#   buc stop                        Close Chrome
#   buc open <url>                  Start + navigate (one-shot)
#   buc nav <url>                   Navigate
#   buc state                       Show numbered clickable elements
#   buc clicki <index>              Click element by number
#   buc clkt <text>                 Click element by text
#   buc click <selector>            Click element by CSS
#   buc type <selector> <text>      Type into input
#   buc send <message>              Type + smart submit
#   buc ss [path]                   Screenshot
#   buc snap                        Accessibility snapshot
#   buc eval <js>                   Run JavaScript
#   buc scroll [up|down|top|bottom] Scroll page
#   buc back                        Navigate back
#   buc wait selector <css>         Wait for element
#   buc wait load [ms]              Wait for page load
#   buc wait <ms>                   Wait N milliseconds
#   buc text [selector]             Get text content
#   buc html [selector]             Get HTML content
#   buc cookies get|set|clear       Cookie management
#   buc frames                      List frames
#   buc tabs                        List open tabs
#   buc newtab <url>                Open new tab
#   buc focus <tab-id>              Bring tab to front
#   buc switch <pattern>            Switch tab by URL/title
#
# HTTP (no browser needed, no gate):
#   buc get <url>                   GET request
#   buc post <url> [data]           POST request
#   buc put <url> [data]            PUT request
#   buc delete <url>                DELETE request
#   buc head <url>                  HEAD request
#   buc dl <url> [path]             Download file
#
# Dependencies: Node.js 22+, Chrome/Chromium/Edge/Brave (CDP-compatible)
# Platforms: Linux, macOS, Windows (WSL)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
CDP="$SCRIPT_DIR/scripts/cdp.mjs"

# Config paths (OS-aware)
if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" || "$OSTYPE" == "win32" ]]; then
  SYS_CONFIG_DIR="/c/ProgramData/buc"
  STATE_DIR="${LOCALAPPDATA:-$HOME/AppData/Local}/buc"
elif [[ "$OSTYPE" == "darwin"* ]]; then
  SYS_CONFIG_DIR="/etc/buc"
  STATE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/buc"
else
  SYS_CONFIG_DIR="/etc/buc"
  STATE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/buc"
fi

USER_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/buc"

# Resolve config path: system config if exists, else user config
CONFIG=""
if [[ -f "$SYS_CONFIG_DIR/config" ]]; then
  CONFIG="$SYS_CONFIG_DIR/config"
elif [[ -f "$USER_CONFIG_DIR/config" ]]; then
  CONFIG="$USER_CONFIG_DIR/config"
else
  CONFIG="$USER_CONFIG_DIR/config"
fi

mkdir -p "$STATE_DIR" 2>/dev/null || true

# Initialize config if missing (disabled by default, no overwrite of existing)
if [[ ! -f "$CONFIG" ]]; then
  mkdir -p "$(dirname "$CONFIG")" 2>/dev/null || true
  echo '{"enabled":false,"mode":"headless"}' > "$CONFIG" 2>/dev/null || true
fi

# Read config value using node (handles booleans and strings, safe for paths and keys with quotes)
cfg() {
  local key="$1"
  node -e "
    const fs = require('fs');
    const path = String.raw\`${CONFIG}\`;
    const key = String.raw\`${key}\`;
    try {
      const cfg = JSON.parse(fs.readFileSync(path, 'utf8'));
      const val = cfg[key];
      if (val === undefined) { process.stdout.write(''); }
      else if (typeof val === 'boolean') { process.stdout.write(val ? 'true' : 'false'); }
      else { process.stdout.write(String(val)); }
    } catch { process.stdout.write(''); }
  " 2>/dev/null
}

# Check if browser is enabled
check_enabled() {
  local enabled
  enabled=$(cfg "enabled")
  if [[ "$enabled" != "true" ]]; then
    echo '{"error":"Browser is disabled. Run: sudo buc on [headed|headless|both]"}' >&2
    exit 1
  fi
}

# Port management (safe with set -u)
SAVED_PORT=9222
[[ -f "$STATE_DIR/default-port" ]] && SAVED_PORT=$(cat "$STATE_DIR/default-port")
PORT="${CDP_PORT:-$SAVED_PORT}"

# Parse --port argument safely
for ((i=1; i<=$#; i++)); do
  if [[ "${!i:-}" == "--port" ]]; then
    next=$((i+1))
    if [[ -n "${!next:-}" ]]; then
      PORT="${!next}"
    fi
  fi
done

STATE="$STATE_DIR/state-$PORT"

# Check CDP script exists
if [[ ! -f "$CDP" ]]; then
  # Try fallback path for installed location
  if [[ -f "/usr/local/lib/buc/scripts/cdp.mjs" ]]; then
    CDP="/usr/local/lib/buc/scripts/cdp.mjs"
  else
    echo '{"error":"cdp.mjs not found at '"$CDP"'"}' >&2
    exit 1
  fi
fi

# Connect to browser
connect_ws() {
  WSURL=$(node "$CDP" connect --port "$PORT" -q 2>/dev/null)
  if [[ -n "$WSURL" ]]; then
    echo "$WSURL" > "$STATE"
    echo "$WSURL"
  else
    echo '{"error":"Cannot connect. Run: buc start --port '"$PORT"'"}' >&2
    exit 1
  fi
}

# Run command on connected browser
cmd() {
  WSURL=$(connect_ws)
  if [[ -z "$WSURL" ]]; then exit 1; fi
  node "$CDP" "$WSURL" "$@" -q
}

# === Toggle commands (require sudo) ===

cmd_status() {
  local enabled=$(cfg "enabled")
  local mode=$(cfg "mode")
  
  if [[ "$enabled" == "true" ]]; then
    echo "Browser: enabled"
  else
    echo "Browser: disabled"
  fi
  
  echo "Mode: ${mode:-headless}"
  echo ""
  
  # Verify CDP connection if state file exists
  if [[ -f "$STATE" ]]; then
    if node "$CDP" connect --port "$PORT" -q >/dev/null 2>&1; then
      echo "Connection: active (port $PORT)"
    else
      echo "Connection: stale (port $PORT)"
      rm -f "$STATE"
    fi
  else
    echo "Connection: inactive"
  fi
  
  echo ""
  echo "To toggle: sudo buc on [headed|headless|both]"
}

cmd_on() {
  local mode="${1:-headless}"
  
  if [[ "$mode" != "headed" && "$mode" != "headless" && "$mode" != "both" ]]; then
    echo '{"error":"Invalid mode. Use: headed, headless, or both"}' >&2
    exit 1
  fi
  
  # Ensure parent directory exists
  sudo mkdir -p "$(dirname "$CONFIG")" 2>/dev/null || true
  echo "{\"enabled\":true,\"mode\":\"$mode\"}" | sudo tee "$CONFIG" > /dev/null
  sudo chown "$(id -u):$(id -g)" "$CONFIG" 2>/dev/null || true
  echo "{\"success\":true,\"enabled\":true,\"mode\":\"$mode\"}"
}

cmd_off() {
  sudo mkdir -p "$(dirname "$CONFIG")" 2>/dev/null || true
  echo '{"enabled":false,"mode":"headless"}' | sudo tee "$CONFIG" > /dev/null
  sudo chown "$(id -u):$(id -g)" "$CONFIG" 2>/dev/null || true
  echo '{"success":true,"enabled":false}'
}

# === Browser commands (require enabled, no sudo) ===

cmd_start() {
  check_enabled
  
  local headless_flag=""
  local mode=$(cfg "mode")
  
  for arg in "$@"; do
    if [[ "${arg:-}" == "--headless" ]]; then
      headless_flag="--headless"
    fi
  done
  
  if [[ -z "$headless_flag" ]]; then
    if [[ "$mode" == "headless" || "$mode" == "" ]]; then
      headless_flag="--headless"
    fi
  fi
  
  node "$CDP" launch $headless_flag --port "$PORT"
  WSURL=$(node "$CDP" connect --port "$PORT" -q 2>/dev/null)
  [[ -n "$WSURL" ]] && echo "$WSURL" > "$STATE"
}

cmd_open() {
  check_enabled
  
  # Check if Chrome is already running
  if ! node "$CDP" connect --port "$PORT" -q >/dev/null 2>&1; then
    node "$CDP" launch --port "$PORT" 2>/dev/null
    # Wait for Chrome to be ready (up to 10 seconds)
    for i in {1..20}; do
      sleep 0.5
      if node "$CDP" connect --port "$PORT" -q >/dev/null 2>&1; then
        break
      fi
    done
  fi
  node "$CDP" connect --port "$PORT" -q > /dev/null 2>&1
  cmd navigate "${1:-}"
}

# === Main ===

case "${1:-}" in
  status)     cmd_status ;;
  on)         cmd_on "${2:-headless}" ;;
  off)        cmd_off ;;
  start)      shift; cmd_start "$@" ;;
  stop)       check_enabled; node "$CDP" close --port "$PORT"; rm -f "$STATE" ;;
  open)       shift; cmd_open "$@" ;;
  nav|navigate)   shift; check_enabled; cmd navigate "$@" ;;
  state)      check_enabled; cmd state ;;
  click|clk)  shift; check_enabled; cmd click "$@" ;;
  click-text|clkt) shift; check_enabled; cmd clkt "$@" ;;
  click-index|clicki) shift; check_enabled; cmd clicki "$@" ;;
  send)       shift; check_enabled; cmd send "$@" ;;
  type|typ)   shift; check_enabled; cmd type "$@" ;;
  press|key)  shift; check_enabled; cmd press "$@" ;;
  ss|screenshot) shift; check_enabled;
    full=""
    path=""
    for arg in "$@"; do
      if [[ "${arg:-}" == "--full" ]]; then full="--full"; else path="$arg"; fi
    done
    cmd screenshot "$path" $full ;;
  snap|snapshot) check_enabled; cmd snapshot ;;
  eval|evaluate) shift; check_enabled; cmd evaluate "$@" ;;
  scroll|sc)  shift; check_enabled; cmd scroll "${1:-down}" ;;
  back|bk)    check_enabled; cmd back ;;
  wait)       shift; check_enabled; cmd wait "$@" ;;
  text|txt)   shift; check_enabled; cmd text "$@" ;;
  html)       shift; check_enabled; cmd html "$@" ;;
  frames)     check_enabled; cmd frames ;;
  cookies)    shift; check_enabled; cmd cookies "$@" ;;
  tabs)       check_enabled; node "$CDP" tabs --port "$PORT" ;;
  newtab)     shift; check_enabled; node "$CDP" newtab "$@" --port "$PORT" ;;
  focus)      shift; check_enabled; node "$CDP" focus "$@" --port "$PORT" ;;
  switch)     shift; check_enabled; node "$CDP" switch "$@" --port "$PORT" ;;
  
  # HTTP commands (no browser needed, no gate)
  http)       shift; node "$CDP" http "$@" -q ;;
  get)        node "$CDP" http GET "${2:-}" -q ;;
  post)       node "$CDP" http POST "${2:-}" "${3:-}" -q ;;
  put)        node "$CDP" http PUT "${2:-}" "${3:-}" -q ;;
  delete|del) node "$CDP" http DELETE "${2:-}" -q ;;
  head)       node "$CDP" http HEAD "${2:-}" -q ;;
  download|dl) shift; node "$CDP" download "$@" -q ;;
  
  # Help
  ""|--help|-h)
    echo "buc — Browser Use CLI"
    echo ""
    echo "Toggle (requires sudo):"
    echo "  buc status                      Show state"
    echo "  buc on [headed|headless|both]   Enable browser"
    echo "  buc off                         Disable browser"
    echo ""
    echo "Browser (requires enabled, no sudo):"
    echo "  buc start [--headless]          Launch Chrome"
    echo "  buc stop                        Close Chrome"
    echo "  buc open <url>                  Start + navigate"
    echo "  buc nav <url>                   Navigate"
    echo "  buc state                       Show clickable elements"
    echo "  buc clicki <index>              Click by number"
    echo "  buc clkt <text>                 Click by text"
    echo "  buc click <selector>            Click by CSS"
    echo "  buc type <selector> <text>      Type text"
    echo "  buc send <message>              Type + submit"
    echo "  buc ss [path]                   Screenshot"
    echo "  buc snap                        Accessibility tree"
    echo "  buc eval <js>                   Run JavaScript"
    echo "  buc scroll [up|down|top|bottom] Scroll"
    echo "  buc back                        Go back"
    echo "  buc wait selector <css> [ms]    Wait for element (default 30s)"
    echo "  buc wait load [ms]              Wait for page load"
    echo "  buc wait <ms>                   Wait N milliseconds"
    echo "  buc text [selector]             Get text"
    echo "  buc html [selector]             Get HTML"
    echo "  buc cookies get|set|clear       Cookies"
    echo "  buc frames                      List frames"
    echo "  buc tabs                        List tabs"
    echo "  buc newtab <url>                New tab"
    echo "  buc focus <tab-id>              Focus tab"
    echo "  buc switch <pattern>            Switch tab"
    echo ""
    echo "HTTP (no browser needed):"
    echo "  buc get <url>                   GET"
    echo "  buc post <url> [data]           POST"
    echo "  buc put <url> [data]            PUT"
    echo "  buc delete <url>                DELETE"
    echo "  buc head <url>                  HEAD"
    echo "  buc dl <url> [path]             Download"
    echo ""
    echo "Port: $PORT (set via --port, CDP_PORT, or saved default)"
    ;;
  *)
    echo '{"error":"Unknown command. Run: buc --help"}' >&2
    exit 1
    ;;
esac
